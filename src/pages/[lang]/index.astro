---
import type { GetStaticPaths } from "astro";
import About from "../../components/About.astro";
import Hero from "../../components/Hero.astro";
import Languages from "../../components/Languages.astro";
import SocialMedia from "../../components/SocialMedia.astro";
import Technologies from "../../components/Technologies.astro";
import Studies from "../../components/Studies.astro";
import { languages, type Locale } from "../../i18n/ui";
import { studies } from "../../data/studies";
import Layout from "../../layouts/Layout.astro";

export const getStaticPaths = (() => {
	const langs = Object.keys(languages);
	return langs.map((l) => ({ params: { lang: l as Locale } }));
}) satisfies GetStaticPaths;
---

<Layout>
	<Hero />
	<Technologies lang={Astro.params.lang} />
	<Studies client:load studies={studies} lang={Astro.params.lang} />
	<About />
	<Languages />
	<SocialMedia />
</Layout>
