---
import { useTranslations } from "../i18n/utils";
import type { Locale } from "../i18n/ui";

interface Study {
  id: string;
  startDate: string;
  endDate: string;
  isCurrent?: boolean;
  certificateUrl?: string;
  certificateName?: string;
}

interface Props {
  studies: Study[];
  lang: Locale;
}

const { studies, lang } = Astro.props;
const t = useTranslations(lang);

// Sort studies by end date (newest first)
const sortedStudies = [...studies].sort(
  (a, b) => new Date(b.endDate).getTime() - new Date(a.endDate).getTime(),
);
---

<section id="studies" class="py-20 px-4 bg-slate-900">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        <span
          class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-cyan-300"
        >
          {t("studies.title")}
        </span>
        &amp; Studies
      </h2>
      <p class="text-gray-300 text-lg">{t("studies.subtitle")}</p>
    </div>

    {/* Timeline */}
    <div class="relative pl-12">
      {/* Vertical line - Left side */}
      <div
        class="absolute left-0 top-0 bottom-0 w-1 bg-linear-to-b from-blue-500 to-cyan-500"
      >
      </div>

      {/* Timeline items */}
      <div class="space-y-12">
        {
          sortedStudies.map((study, index) => (
            <div class="relative study-item">
              {/* Timeline dot */}
              <div
                class={`absolute left-0 top-6 w-4 h-4 rounded-full border-4 border-slate-900 transform -translate-x-2.5 ${
                  index % 2 === 0 ? "bg-blue-500" : "bg-cyan-500"
                }`}
              />

              {/* Card */}
              <div
                class={`bg-linear-to-br rounded-lg p-6 transition-all duration-300 ${
                  study.isCurrent
                    ? "from-blue-500/30 to-cyan-500/20 border-2 border-cyan-400 shadow-lg shadow-cyan-500/20"
                    : "from-blue-900/30 to-slate-800/30 border border-blue-500/20 hover:border-blue-400/50 hover:shadow-lg hover:shadow-blue-500/10"
                }`}
              >
                {/* Date and Current Badge */}
                <div class="flex items-center justify-between mb-2">
                  <p class="text-blue-300 text-sm font-semibold">
                    {study.startDate} -{" "}
                    {study.isCurrent ? "Present" : study.endDate}
                  </p>
                  {study.isCurrent && (
                    <span class="inline-flex items-center gap-1 px-2 py-1 bg-cyan-500/30 border border-cyan-400 rounded-full text-xs font-semibold text-cyan-300 animate-pulse">
                      <span class="w-2 h-2 rounded-full bg-cyan-400" />
                      {t("studies.inProgress")}
                    </span>
                  )}
                </div>

                {/* Institution */}
                <h3 class="text-xl font-bold text-white mb-1">
                  {t(`studies.${study.id}.institution` as any)}
                </h3>

                {/* Degree */}
                <p class="text-lg text-cyan-300 font-semibold mb-3">
                  {t(`studies.${study.id}.degree` as any)} in{" "}
                  {t(`studies.${study.id}.field` as any)}
                </p>

                {/* Description */}
                {t(`studies.${study.id}.description` as any) && (
                  <p class="text-gray-300 mb-4 leading-relaxed">
                    {t(`studies.${study.id}.description` as any)}
                  </p>
                )}

                {/* Certificate button */}
                {study.certificateUrl && (
                  <a
                    href={study.certificateUrl}
                    download={study.certificateName}
                    class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors font-medium text-sm"
                  >
                    <svg
                      class="w-4 h-4"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width={2}
                        d="M12 19l9 2-9-18-9 18 9-2m0 0v-8m0 8a9 9 0 0118 0m-18 0a9 9 0 0018 0"
                      />
                    </svg>
                    {t("studies.downloadCert")}
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .study-item {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }

  .study-item.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const items = document.querySelectorAll(".study-item");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("visible");
          observer.unobserve(entry.target); // animate once
        }
      });
    },
    { threshold: 0.15 },
  );

  items.forEach((item, index) => {
    // stagger each card slightly
    (item as HTMLElement).style.transitionDelay = `${index * 100}ms`;
    observer.observe(item);
  });
</script>
