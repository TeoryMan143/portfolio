---
// Technologies and Skills section
const skills = [
  { name: 'React', category: 'Frontend' },
  { name: 'TypeScript', category: 'Language' },
  { name: 'Astro', category: 'Framework' },
  { name: 'Tailwind CSS', category: 'Styling' },
  { name: 'Node.js', category: 'Backend' },
  { name: 'JavaScript', category: 'Language' },
  { name: 'CSS/HTML', category: 'Frontend' },
  { name: 'Git', category: 'Tools' },
];

const categories = {
  Frontend: ['React', 'Astro', 'Tailwind CSS', 'CSS/HTML'],
  Language: ['TypeScript', 'JavaScript'],
  Backend: ['Node.js'],
  Tools: ['Git'],
};
---

<section id='technologies' class='py-20 px-4 bg-slate-800'>
  <div class='max-w-6xl mx-auto'>
    <div class='text-center mb-16'>
      <h2 class='text-4xl md:text-5xl font-bold text-white mb-4'>
        Technologies & <span
          class='text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-300'
          >Skills</span
        >
      </h2>
      <p class='text-gray-300 text-lg'>
        Here's what I work with to create amazing experiences
      </p>
    </div>

    <!-- Skills Grid -->
    <div class='grid grid-cols-2 md:grid-cols-4 gap-4 mb-12'>
      {
        skills.map(skill => (
          <div class='group p-6 bg-gradient-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg hover:border-blue-400/60 transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/20 cursor-pointer transform hover:scale-105'>
            <p class='text-center font-semibold text-gray-200 group-hover:text-blue-300 transition-colors'>
              {skill.name}
            </p>
            <p class='text-center text-sm text-gray-400 mt-2'>
              {skill.category}
            </p>
          </div>
        ))
      }
    </div>

    <!-- Summary -->
    <div
      class='bg-gradient-to-r from-blue-900/30 to-slate-800/30 border border-blue-500/20 rounded-lg p-8'
    >
      <h3 class='text-xl font-bold text-blue-300 mb-4'>What I Do</h3>
      <ul class='text-gray-300 space-y-2'>
        <li class='flex items-start'>
          <span class='text-blue-400 mr-3'>✓</span>
          <span>Build responsive and accessible web applications</span>
        </li>
        <li class='flex items-start'>
          <span class='text-blue-400 mr-3'>✓</span>
          <span>Design modern user interfaces with great UX principles</span>
        </li>
        <li class='flex items-start'>
          <span class='text-blue-400 mr-3'>✓</span>
          <span>Develop full-stack solutions from concept to deployment</span>
        </li>
        <li class='flex items-start'>
          <span class='text-blue-400 mr-3'>✓</span>
          <span>Collaborate with teams to deliver high-quality products</span>
        </li>
      </ul>
    </div>
  </div>
</section>
