---
// Social media links section
const socialLinks = [
  {
    name: 'GitHub',
    icon: 'github',
    url: 'https://github.com',
    color: 'hover:text-gray-300',
  },
  {
    name: 'LinkedIn',
    icon: 'linkedin',
    url: 'https://linkedin.com',
    color: 'hover:text-blue-300',
  },
  {
    name: 'Twitter',
    icon: 'twitter',
    url: 'https://twitter.com',
    color: 'hover:text-blue-400',
  },
  {
    name: 'Email',
    icon: 'email',
    url: 'mailto:your.email@example.com',
    color: 'hover:text-cyan-300',
  },
];
---

<section
  id='social'
  class='py-16 px-4 bg-gradient-to-b from-slate-800 to-slate-900'
>
  <div class='max-w-6xl mx-auto'>
    <div class='text-center mb-12'>
      <h2 class='text-3xl md:text-4xl font-bold text-white mb-2'>
        Let's Connect
      </h2>
      <p class='text-gray-400'>Follow me on social media</p>
    </div>

    <!-- Social Links -->
    <div class='flex justify-center gap-8 mb-12'>
      {
        socialLinks.map(link => (
          <a
            href={link.url}
            target='_blank'
            rel='noopener noreferrer'
            aria-label={link.name}
            class={`group relative p-4 bg-blue-900/30 border border-blue-500/30 rounded-full transition-all duration-300 hover:border-blue-400/60 hover:shadow-lg hover:shadow-blue-500/20 transform hover:scale-110 ${link.color}`}
          >
            {link.icon === 'github' && (
              <svg
                class='w-6 h-6 text-blue-300'
                fill='currentColor'
                viewBox='0 0 24 24'
              >
                <path d='M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z' />
              </svg>
            )}
            {link.icon === 'linkedin' && (
              <svg
                class='w-6 h-6 text-blue-300'
                fill='currentColor'
                viewBox='0 0 24 24'
              >
                <path d='M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.735-2.004 1.438-.103.25-.129.599-.129.949v5.418h-3.554s.05-8.789 0-9.514h3.554v1.347c.42-.648 1.36-1.573 3.322-1.573 2.429 0 4.251 1.547 4.251 4.875v5.865zM5.337 8.855c-1.144 0-1.915-.759-1.915-1.71 0-.956.77-1.71 1.964-1.71 1.192 0 1.915.754 1.938 1.71 0 .951-.746 1.71-1.987 1.71zm1.581 11.597H3.756V9.338h3.162v11.114zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z' />
              </svg>
            )}
            {link.icon === 'twitter' && (
              <svg
                class='w-6 h-6 text-blue-300'
                fill='currentColor'
                viewBox='0 0 24 24'
              >
                <path d='M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7a10.6 10.6 0 01-9-5.5z' />
              </svg>
            )}
            {link.icon === 'email' && (
              <svg
                class='w-6 h-6 text-blue-300'
                fill='currentColor'
                viewBox='0 0 24 24'
              >
                <path d='M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z' />
              </svg>
            )}
            <span class='absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 px-3 py-1 bg-slate-700 text-blue-300 text-sm rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap'>
              {link.name}
            </span>
          </a>
        ))
      }
    </div>

    <!-- Contact CTA -->
    <div class='text-center'>
      <p class='text-gray-300 mb-4'>Ready to work together?</p>
      <a
        href='mailto:your.email@example.com'
        class='inline-block px-8 py-3 bg-gradient-to-r from-blue-500 to-cyan-500 text-white font-semibold rounded-lg hover:from-blue-600 hover:to-cyan-600 transition-all transform hover:scale-105 shadow-lg'
      >
        Send Me an Email
      </a>
    </div>
  </div>
</section>
