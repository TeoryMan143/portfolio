---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import LanguagePicker from "./LanguagePicker.astro";
import { MobileNavButton, MobileNavDrawer } from "./MobileNav";

const lang = getLangFromUrl(Astro.url);
// biome-ignore lint/correctness/useHookAtTopLevel: THIS IS NOT REACT
const t = useTranslations(lang);

const navLinks = [
  { label: t("nav.home"), href: `/${lang}#` },
  { label: t("nav.technologies"), href: `/${lang}#technologies` },
  { label: t("nav.about"), href: `/${lang}#about` },
  { label: t("nav.social"), href: `/${lang}#social` },
];
---

<nav
  class="fixed top-0 w-full bg-slate-900/80 backdrop-blur-md z-50 border-b border-blue-500/20"
>
  <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
    <!-- Logo -->
    <div class="flex items-center gap-2">
      <div
        class="w-10 h-10 bg-linear-to-br from-blue-400 to-cyan-300 rounded-lg flex items-center justify-center font-bold text-slate-900"
      >
        TM
      </div>
      <span class="font-bold text-white">TeoryMan</span>
    </div>

    <!-- Nav Links -->
    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-300 hover:text-blue-300 transition-colors font-medium"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Language Picker -->
    <LanguagePicker />

    <!-- Mobile Menu Button (inside nav) -->
    <MobileNavButton client:load />
  </div>
</nav>

<!-- Mobile Menu Drawer (outside nav to escape stacking context) -->
<MobileNavDrawer client:load navLinks={navLinks}>
  <LanguagePicker />
</MobileNavDrawer>
