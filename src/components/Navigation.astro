---
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const navLinks = [
  { label: "Home", href: `/${lang}#` },
  { label: "Technologies", href: `/${lang}#technologies` },
  { label: "About", href: `/${lang}#about` },
  { label: "Social", href: `/${lang}#social` },
];
---

<nav
  class="fixed top-0 w-full bg-slate-900/80 backdrop-blur-md z-50 border-b border-blue-500/20"
>
  <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
    <!-- Logo -->
    <div class="flex items-center gap-2">
      <div
        class="w-10 h-10 bg-linear-to-br from-blue-400 to-cyan-300 rounded-lg flex items-center justify-center font-bold text-slate-900"
      >
        TM
      </div>
    </div>

    <!-- Nav Links -->
    <div class="hidden md:flex items-center gap-8">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-300 hover:text-blue-300 transition-colors font-medium"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- CTA Button -->
    <a
      href="#contact"
      class="hidden md:block px-6 py-2 bg-linear-to-r from-blue-500 to-cyan-500 text-white font-semibold rounded-lg hover:from-blue-600 hover:to-cyan-600 transition-all text-sm"
    >
      Contact
    </a>

    <!-- Mobile Menu Button -->
    <button class="md:hidden text-gray-300 hover:text-blue-300" type="button">
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <title>Options</title>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</nav>
