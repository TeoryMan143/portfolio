---
import { useTranslations } from "../i18n/utils";
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Language {
  name: string;
  level: string;
  proficiency: number;
  certificate?: boolean;
  certificateUrl?: string;
}

const languages: Language[] = [
  {
    name: "Spanish",
    level: "Native",
    proficiency: 100,
  },
  {
    name: "English",
    level: "C1",
    proficiency: 100,
    certificate: true,
    certificateUrl: "/certificates/english-certificate.pdf",
  },
  {
    name: "Portuguese",
    level: "B2",
    proficiency: 70,
  },
];
---

<section id="languages" class="py-20 px-4 bg-slate-800">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        <span
          class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-cyan-300"
        >
          {t("languages.title")}
        </span>
      </h2>
      <p class="text-gray-300 text-lg">{t("languages.subtitle")}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        languages.map((lang) => (
          <div class="bg-linear-to-br from-blue-900/30 to-slate-800/30 border border-blue-500/20 rounded-lg p-6 hover:border-blue-400/50 transition-all duration-300 hover:shadow-lg hover:shadow-blue-500/10">
            {/* Language Name and Level */}
            <div class="mb-4">
              <h3 class="text-xl font-bold text-white mb-1">{lang.name}</h3>
              <div class="flex items-center justify-between">
                <p class="text-cyan-300 font-semibold text-sm">{lang.level}</p>
                {lang.certificate && (
                  <a
                    href={lang.certificateUrl}
                    download
                    class="inline-flex items-center gap-1 px-2 py-1 text-xs bg-blue-500/30 border border-blue-400 rounded text-blue-300 hover:bg-blue-500/50 transition-colors"
                    title="Download Certificate"
                  >
                    <svg
                      class="w-3 h-3"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                    </svg>
                    Cert
                  </a>
                )}
              </div>
            </div>

            {/* Proficiency Bar */}
            <div class="space-y-2">
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs text-gray-400">
                  {t("languages.proficiency")}
                </span>
                <span class="text-xs font-semibold text-blue-300">
                  {lang.proficiency}%
                </span>
              </div>
              <div class="w-full h-2 bg-slate-700 rounded-full overflow-hidden">
                <div
                  class="h-full bg-linear-to-r from-blue-500 to-cyan-400 rounded-full transition-all duration-500"
                  style={`width: ${lang.proficiency}%`}
                />
              </div>
            </div>

            {/* Framework/Common Skills for Language */}
            <div class="mt-4 pt-4 border-t border-blue-500/20">
              <p class="text-xs text-gray-400">
                {t(`languages.${lang.name.toLowerCase()}.description` as any)}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
