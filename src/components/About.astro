---
// About section
---

<section id='about' class='py-20 px-4 bg-slate-800'>
  <div class='max-w-4xl mx-auto'>
    <div class='grid grid-cols-1 md:grid-cols-2 gap-12 items-center'>
      <!-- Stats -->
      <div>
        <h2 class='text-4xl md:text-5xl font-bold text-white mb-8'>
          About <span
            class='text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-cyan-300'
            >Me</span
          >
        </h2>

        <p class='text-gray-300 mb-6 leading-relaxed'>
          I'm a passionate developer with a love for creating beautiful and
          functional web experiences. With several years of experience in web
          development, I've worked on diverse projects ranging from small
          startups to larger organizations.
        </p>

        <p class='text-gray-300 mb-8 leading-relaxed'>
          When I'm not coding, you can find me exploring new technologies,
          contributing to open source projects, or sharing knowledge with the
          community.
        </p>

        <a
          href='#contact'
          class='inline-block px-6 py-2 bg-blue-500/20 border border-blue-400/50 text-blue-300 font-semibold rounded-lg hover:bg-blue-500/30 hover:border-blue-300 transition-all'
        >
          Learn More
        </a>
      </div>

      <!-- Stats Grid -->
      <div class='grid grid-cols-2 gap-6'>
        <div
          class='bg-linear-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg p-8 text-center hover:border-blue-400/60 transition-all'
        >
          <p class='text-3xl font-bold text-blue-300 mb-2'>50+</p>
          <p class='text-gray-300 text-sm'>Projects Completed</p>
        </div>

        <div
          class='bg-linear-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg p-8 text-center hover:border-blue-400/60 transition-all'
        >
          <p class='text-3xl font-bold text-blue-300 mb-2'>5+</p>
          <p class='text-gray-300 text-sm'>Years Experience</p>
        </div>

        <div
          class='bg-linear-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg p-8 text-center hover:border-blue-400/60 transition-all'
        >
          <p class='text-3xl font-bold text-blue-300 mb-2'>30+</p>
          <p class='text-gray-300 text-sm'>Happy Clients</p>
        </div>

        <div
          class='bg-linear-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg p-8 text-center hover:border-blue-400/60 transition-all'
        >
          <p class='text-3xl font-bold text-blue-300 mb-2'>100%</p>
          <p class='text-gray-300 text-sm'>Dedication</p>
        </div>
      </div>
    </div>
  </div>
</section>
