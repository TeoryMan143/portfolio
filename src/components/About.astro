---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
// biome-ignore lint/correctness/useHookAtTopLevel: THIS IS NOT REACT
const t = useTranslations(lang);
---

<section id="about" class="py-20 px-4 bg-slate-800">
  <div class="max-w-4xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Stats -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-8">
          {t("about.title")}
          <span
            class="text-transparent bg-clip-text bg-linear-to-r from-blue-400 to-cyan-300"
            >{t("about.subtitle")}</span
          >
        </h2>

        <p class="text-gray-300 mb-6 leading-relaxed">
          {t("about.description1")}
        </p>

        <p class="text-gray-300 mb-8 leading-relaxed">
          {t("about.description2")}
        </p>

        <a
          href="#social"
          class="inline-block px-6 py-2 bg-blue-500/20 border border-blue-400/50 text-blue-300 font-semibold rounded-lg hover:bg-blue-500/30 hover:border-blue-300 transition-all"
        >
          {t("about.learnMore")}
        </a>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-2 gap-6">
        <div
          class="bg-linear-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg p-8 text-center hover:border-blue-400/60 transition-all"
        >
          <p class="text-3xl font-bold text-blue-300 mb-2">
            {t("about.projectsCount")}
          </p>
          <p class="text-gray-300 text-sm">{t("about.projects")}</p>
        </div>

        <div
          class="bg-linear-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg p-8 text-center hover:border-blue-400/60 transition-all"
        >
          <p class="text-3xl font-bold text-blue-300 mb-2">
            {t("about.experienceCount")}
          </p>
          <p class="text-gray-300 text-sm">{t("about.experience")}</p>
        </div>

        <div
          class="bg-linear-to-br from-blue-900/50 to-slate-800/50 border border-blue-500/30 rounded-lg p-8 text-center hover:border-blue-400/60 transition-all col-span-2"
        >
          <p class="text-3xl font-bold text-blue-300 mb-2">
            {t("about.dedicationCount")}
          </p>
          <p class="text-gray-300 text-sm">{t("about.dedication")}</p>
        </div>
      </div>
    </div>
  </div>
</section>
