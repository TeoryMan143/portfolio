---
import { getLangFromUrl } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);

const navLinks = [
  { label: "Home", href: `/${lang}#` },
  { label: "Technologies", href: `/${lang}#technologies` },
  { label: "About", href: `/${lang}#about` },
  { label: "Social", href: `/${lang}#social` },
];
---

<footer class="bg-slate-950 border-t border-blue-500/20 px-4 py-12">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div
            class="w-8 h-8 bg-linear-to-br from-blue-400 to-cyan-300 rounded-lg flex items-center justify-center font-bold text-slate-900 text-sm"
          >
            TM
          </div>
          <span class="font-bold text-white">Portfolio</span>
        </div>
        <p class="text-gray-400 text-sm">Building amazing web experiences</p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Quick Links</h3>
        <ul class="space-y-2">
          {
            navLinks.map(({ href, label }) => (
              <li>
                <a
                  href={href}
                  class="text-gray-400 hover:text-blue-300 text-sm transition-colors"
                >
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Social Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Follow Me</h3>
        <div class="flex gap-4">
          <a
            href="https://github.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-blue-300 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <title>Github</title>
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
          </a>
          <a
            href="https://linkedin.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-blue-300 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <title>LinkedIn</title>
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.735-2.004 1.438-.103.25-.129.599-.129.949v5.418h-3.554s.05-8.789 0-9.514h3.554v1.347c.42-.648 1.36-1.573 3.322-1.573 2.429 0 4.251 1.547 4.251 4.875v5.865zM5.337 8.855c-1.144 0-1.915-.759-1.915-1.71 0-.956.77-1.71 1.964-1.71 1.192 0 1.915.754 1.938 1.71 0 .951-.746 1.71-1.987 1.71zm1.581 11.597H3.756V9.338h3.162v11.114zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"
              ></path>
            </svg>
          </a>
          <a
            href="https://twitter.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-blue-300 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <title>Twitter</title>
              <path
                d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7a10.6 10.6 0 01-9-5.5z"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-blue-500/20 pt-8">
      <p class="text-gray-400 text-sm text-center">
        © 2024 Your Name. All rights reserved. Built with <span
          class="text-blue-400">Astro</span
        > & <span class="text-blue-400">Tailwind CSS</span>.
      </p>
    </div>
  </div>
</footer>
