---
import { languages } from "../i18n/ui";
import { getLangFromUrl } from "../i18n/utils";

const currentLang = getLangFromUrl(Astro.url);
const availableLanguages = Object.entries(languages);

// Get the current path without the language prefix
const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const currentPath = pathSegments.slice(1).join("/");
---

<div class="relative group">
  <button
    class="hidden md:flex items-center gap-2 px-4 py-2 bg-slate-800/50 border border-blue-500/30 text-gray-300 font-medium rounded-lg hover:border-blue-400/60 hover:bg-slate-800/80 transition-all text-sm"
    aria-label="Select language"
    type="button"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="1em"
      height="1em"
      viewBox="0 0 24 24"
    >
      <title>Language</title>
      <path
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="m10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 0 1 6-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138A47.63 47.63 0 0 1 15 5.621m-4.589 8.495a18.023 18.023 0 0 1-3.827-5.802"
      ></path></svg
    >
    <span>{languages[currentLang as keyof typeof languages]}</span>
    <svg
      class="w-3 h-3 transition-transform group-hover:rotate-180"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <title>Dropdown</title>
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </button>

  <!-- Dropdown Menu -->
  <div
    class="absolute right-0 mt-0 w-40 bg-slate-800 border border-blue-500/30 rounded-lg shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
  >
    {
      availableLanguages.map(([langCode, langName]) => {
        const isActive = langCode === currentLang;
        const newPath = currentPath
          ? `/${langCode}/${currentPath}`
          : `/${langCode}`;

        return (
          <a
            href={newPath}
            class={`block w-full text-left px-4 py-3 transition-colors ${
              isActive
                ? "bg-blue-500/20 text-blue-300 font-semibold border-l-2 border-blue-500"
                : "text-gray-300 hover:bg-slate-700/50 hover:text-blue-300"
            } ${langCode !== availableLanguages[availableLanguages.length - 1][0] ? "border-b border-slate-700" : ""}`}
          >
            {langName}
          </a>
        );
      })
    }
  </div>

  <!-- Mobile Menu -->
  <div class="md:hidden flex gap-1">
    {
      availableLanguages.map(([langCode]) => {
        const isActive = langCode === currentLang;
        const newPath = currentPath
          ? `/${langCode}/${currentPath}`
          : `/${langCode}`;

        return (
          <a
            href={newPath}
            class={`px-2 py-1 rounded text-xs font-medium transition-colors ${
              isActive
                ? "bg-blue-500/30 text-blue-300 border border-blue-400"
                : "text-gray-400 hover:text-blue-300"
            }`}
          >
            {langCode.toUpperCase()}
          </a>
        );
      })
    }
  </div>
</div>
